<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:DivAcerManagerMax"
        xmlns:material="using:Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"

        x:Class="DivAcerManagerMax.MainWindow"
        Title="DAMX"
        Icon="iconTransparent.png"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="Full"
        Background="#0e0e11"

        Width="1200" Height="700"
        MinWidth="1200" MinHeight="480">


    <Grid>

        <Grid RowDefinitions="Auto,*">

            <!-- App Header -->
            <Image Source="closeupTransparent.png" Height="40" Margin="0" HorizontalAlignment="Center"
                   VerticalAlignment="Bottom" />
            <Border Grid.Row="0" Padding="0 20 0 0" CornerRadius="20">

                <StackPanel HorizontalAlignment="Right" Margin="0" Orientation="Horizontal">

                    <TextBlock Text="Div Acer Manager MAX" FontSize="26" FontWeight="Bold"
                               LetterSpacing="4" VerticalAlignment="Bottom"
                               HorizontalAlignment="Right" Margin="0 0 20 0"
                               FontFamily="{StaticResource OxaniumBoldFont}">
                        <TextBlock.Foreground>


                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%, 100%">
                                <GradientStop Offset="0" Color="#72bff4" />
                                <GradientStop Offset="1" Color="#3678c3" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>

                </StackPanel>
            </Border>


            <!-- Main Content -->
            <TabControl Grid.Row="1" Margin="10,0,10,10" CornerRadius="20" Background="#18181b" BorderBrush="#18181b"
                        BorderThickness="5" TabStripPlacement="Left">

                <TabItem Header="Dashboard" Tag="loc:Tabs.Dashboard">

                    <views:Dashboard />

                </TabItem>

                <TabItem Header="Fan Profiles" Tag="loc:Tabs.FanProfiles">

                    <views:FanProfiles />

                </TabItem>

                <!-- Power & Performance Tab -->
                <TabItem Header="Power &amp; Performance" Tag="loc:Tabs.PowerPerformance">
                    <ScrollViewer>
                        <StackPanel Margin="10,0,20,0">
                            <TextBlock Text="Power &amp; Performance" Tag="loc:Power.Title" Classes="SectionHeader" />

                            <Border Classes="Card" x:Name="ThermalProfilePanel">
                                <StackPanel>
                                    <!-- Header row with switch -->
                                    <Grid ColumnDefinitions="*,Auto" Margin="0 0 0 10">
                                        <TextBlock Text="Performance Profiles" Tag="loc:Power.PerformanceProfiles" Classes="SubHeader"
                                                   VerticalAlignment="Center" />
                                        <ToggleSwitch x:Name="PluggedInToggleSwitch" Grid.Column="1"
                                                      VerticalAlignment="Center" IsChecked="True"
                                                      IsHitTestVisible="False">
                                            <ToggleSwitch.OffContent>
                                                <material:MaterialIcon Kind="BatteryOutline" Width="24" Height="24" />
                                            </ToggleSwitch.OffContent>
                                            <ToggleSwitch.OnContent>
                                                <material:MaterialIcon Kind="PowerPlugOutline" Width="24" Height="24" />
                                            </ToggleSwitch.OnContent>
                                        </ToggleSwitch>
                                    </Grid>

                                    <TextBlock Text="Configure thermal profiles to balance performance and temperature"
                                               Tag="loc:Power.ProfileHelp"
                                               Opacity="0.7" Margin="0 0 0 10" />

                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0 10">
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal"
                                                    Margin="0 10 0 0" HorizontalAlignment="Center">
                                            <RadioButton x:Name="LowPowerProfileButton" GroupName="ProfileGroup"
                                                         Margin="0 0 15 0"
                                                         IsVisible="{Binding ElementName=PluggedInToggleSwitch, Path=!IsChecked}">
                                                <StackPanel>
                                                    <material:MaterialIcon Kind="Leaf" Width="48" Height="48" />
                                                    <TextBlock Text="Eco" Tag="loc:Power.Eco" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </RadioButton>

                                            <RadioButton x:Name="QuietProfileButton" GroupName="ProfileGroup"
                                                         Margin="0 0 15 0"
                                                         IsVisible="{Binding ElementName=PluggedInToggleSwitch, Path=IsChecked}">
                                                <StackPanel>
                                                    <material:MaterialIcon Kind="FanMinus" Width="48" Height="48" />
                                                    <TextBlock Text="Quiet" Tag="loc:Power.Quiet" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </RadioButton>

                                            <RadioButton x:Name="BalancedProfileButton" GroupName="ProfileGroup"
                                                         Margin="0 0 15 0" IsChecked="True">
                                                <StackPanel>
                                                    <material:MaterialIcon Kind="Bicycle" Width="48" Height="48" />
                                                    <TextBlock Text="Balanced" Tag="loc:Power.Balanced" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </RadioButton>

                                            <RadioButton x:Name="PerformanceProfileButton" GroupName="ProfileGroup"
                                                         Margin="0 0 15 0"
                                                         IsVisible="{Binding ElementName=PluggedInToggleSwitch, Path=IsChecked}">
                                                <StackPanel>
                                                    <material:MaterialIcon Kind="CarSide" Width="48" Height="48" />
                                                    <TextBlock Text="Performance" Tag="loc:Power.Performance" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </RadioButton>

                                            <RadioButton x:Name="TurboProfileButton" GroupName="ProfileGroup"
                                                         Margin="0 0 15 0"
                                                         IsVisible="{Binding ElementName=PluggedInToggleSwitch, Path=IsChecked}">
                                                <StackPanel>
                                                    <material:MaterialIcon Kind="RocketLaunch" Width="48" Height="48" />
                                                    <TextBlock Text="Turbo" Tag="loc:Power.Turbo" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </RadioButton>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock x:Name="ThermalProfileInfoText" Opacity="0.7"
                                               Text="Performance profiles are preset modes that control your device's speed, power use, and cooling:"
                                               Tag="loc:Power.ProfileIntro"
                                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!-- Fan Speed Control -->
                            <Border Classes="Card" x:Name="FanControlPanel">
                                <StackPanel>
                                    <TextBlock Text="Fan Speed Control" Tag="loc:Power.FanSpeedControl" Classes="SubHeader" />
                                    <TextBlock Text="Set custom fan speeds for CPU and GPU" Tag="loc:Power.FanSpeedHelp" Opacity="0.7"
                                               Margin="0 0 0 10" />

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <RadioButton x:Name="AutoFanSpeedRadioButton" GroupName="FanModeGroup"
                                                     Margin="0 0 15 0" IsChecked="True">
                                            <StackPanel>
                                                <material:MaterialIcon Kind="AutoAwesome" Width="48" Height="48" />
                                                <TextBlock Text="Auto" Tag="loc:Common.Auto" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </RadioButton>

                                        <RadioButton x:Name="MaxFanSpeedRadioButton" GroupName="FanModeGroup"
                                                     Margin="0 0 15 0"
                                                     Click="MaxFanSpeedRadioButton_OnClick">
                                            <StackPanel>
                                                <material:MaterialIcon Kind="Turbine" Width="48" Height="48" />
                                                <TextBlock Text="Max" Tag="loc:Power.Max" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </RadioButton>

                                        <RadioButton x:Name="ManualFanSpeedRadioButton" GroupName="FanModeGroup"
                                                     Margin="0 0 15 0">
                                            <StackPanel>
                                                <material:MaterialIcon Kind="CarManualTransmission" Width="48"
                                                                       Height="48" />
                                                <TextBlock Text="Manual" Tag="loc:Power.Manual" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </RadioButton>

                                    </StackPanel>
                                    <TextBlock x:Name="ManualDisabledInfoText" Opacity="0.5"
                                               Text="Manual fan controls are disabled to ensure quiet operation"
                                               Tag="loc:Power.ManualDisabled"
                                               HorizontalAlignment="Center" Margin="0,20,0 ,0"
                                               IsVisible="{Binding ElementName=QuietProfileButton, Path=IsChecked}" />

                                    <StackPanel
                                        IsVisible="{Binding ElementName=ManualFanSpeedRadioButton , Path=IsChecked}">

                                        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto"
                                              Margin="0 5">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU Fan:" Tag="loc:Power.CpuFan"
                                                       VerticalAlignment="Center" Width="80" />
                                            <Slider x:Name="CpuFanSlider" Grid.Row="0" Grid.Column="1" Value="50" />
                                            <TextBlock x:Name="CpuFanTextBlock" Grid.Row="0" Grid.Column="2"
                                                       Text="50%"
                                                       Width="50" TextAlignment="Right" />

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="GPU Fan:" Tag="loc:Power.GpuFan"
                                                       VerticalAlignment="Center" Width="80" Margin="0 15 0 0" />
                                            <Slider x:Name="GpuFanSlider" Grid.Row="1" Grid.Column="1" Value="70"
                                                    Margin="0 15 0 0" />
                                            <TextBlock x:Name="GpuFanTextBlock" Grid.Row="1" Grid.Column="2"
                                                       Text="70%"
                                                       Width="50" TextAlignment="Right" Margin="0 15 0 0" />
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" Margin="0 15 0 0">
                                            <Button x:Name="SetManualSpeedButton" Content="Apply Fan Settings" Tag="loc:Power.ApplyFanSettings"
                                                    Margin="0 0 10 0" Click="SetManualSpeedButton_OnClick" />
                                        </StackPanel>

                                        <TextBlock Text="Note: Low fan speeds may result in higher temperatures" Tag="loc:Power.LowFanNote"
                                                   Foreground="#FFA500" Margin="0 10 0 0" FontSize="12" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Power Controls Tab -->
                <TabItem Header="Battery Controls" Tag="loc:Tabs.BatteryControls" x:Name="BatteryPanel">
                    <ScrollViewer>
                        <StackPanel Margin="10,0,20,0">
                            <TextBlock Text="Power Controls" Tag="loc:Battery.Title" Classes="SectionHeader" />

                            <!-- Battery Calibration -->
                            <Border Classes="Card" x:Name="CalibrationControls">
                                <StackPanel>
                                    <TextBlock Text="Battery Calibration" Tag="loc:Battery.Calibration" Classes="SubHeader" />
                                    <TextBlock
                                        Text="Calibrate your battery to get accurate battery percentage readings"
                                        Tag="loc:Battery.CalibrationHelp"
                                        Opacity="0.7" TextWrapping="Wrap" Margin="0 0 0 10" />

                                    <Grid ColumnDefinitions="*,Auto" Margin="0 10">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="CalibrationStatusTextBlock"
                                                       Text="Status: Not calibrating" Tag="loc:Battery.StatusIdle" FontWeight="SemiBold" />
                                            <TextBlock
                                                Text="Battery calibration will fully charge, drain, and recharge your battery."
                                                Tag="loc:Battery.CalibrationProcess"
                                                TextWrapping="Wrap" Margin="0 5 0 0" Opacity="0.7" />
                                            <TextBlock Text="Do not unplug AC power during calibration." Tag="loc:Battery.DoNotUnplug"
                                                       Foreground="#FFA500" Margin="0 5 0 0" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Vertical">
                                            <Button x:Name="StartCalibrationButton" Content="Start Calibration" Tag="loc:Battery.StartCalibration"
                                                    Margin="0 0 0 5" />
                                            <Button x:Name="StopCalibrationButton" Content="Stop Calibration" Tag="loc:Battery.StopCalibration"
                                                    IsEnabled="False" Background="#444444" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Charge Limit -->
                            <Border Classes="Card" x:Name="LimiterControls">
                                <StackPanel>
                                    <TextBlock Text="Battery Charge Limit" Tag="loc:Battery.ChargeLimit" Classes="SubHeader" />
                                    <TextBlock Text="Limit maximum battery charge to extend battery lifespan" Tag="loc:Battery.ChargeLimitHelp"
                                               Opacity="0.7" Margin="0 0 0 10" />

                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0 10">
                                        <CheckBox x:Name="BatteryLimitCheckBox" Grid.Column="0"
                                                  Content="Enable Battery Limit" Tag="loc:Battery.EnableLimit" Margin="0 0 10 0" />
                                        <TextBlock Grid.Column="2" Text="Limit to 80%" Tag="loc:Battery.Limit80" VerticalAlignment="Center" />
                                    </Grid>

                                    <TextBlock Text="Recommended for laptops that are frequently connected to AC power" Tag="loc:Battery.Recommended"
                                               Opacity="0.7" TextWrapping="Wrap" Margin="0 10 0 0" />
                                </StackPanel>
                            </Border>

                            <!-- USB Power Delivery -->
                            <Border Classes="Card" x:Name="UsbChargingPanel">
                                <StackPanel>
                                    <TextBlock Text="USB Power Delivery" Tag="loc:Battery.UsbPowerDelivery" Classes="SubHeader" />
                                    <TextBlock Text="Configure USB charging when laptop is powered off" Tag="loc:Battery.UsbPowerHelp" Opacity="0.7"
                                               Margin="0 0 0 10" />

                                    <ComboBox x:Name="UsbChargingComboBox" SelectedIndex="2" Width="300"
                                              HorizontalAlignment="Left" Margin="0 10"
                                              SelectionChanged="UsbChargingComboBox_OnSelectionChanged">
                                        <ComboBoxItem Content="Disabled" Tag="loc:Common.Disabled" />
                                        <ComboBoxItem Content="Until battery reaches 10%" Tag="loc:Battery.Until10" />
                                        <ComboBoxItem Content="Until battery reaches 20%" Tag="loc:Battery.Until20" />
                                        <ComboBoxItem Content="Until battery reaches 30%" Tag="loc:Battery.Until30" />
                                    </ComboBox>

                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </ScrollViewer>
                </TabItem>

                <!-- Keyboard Lighting Tab -->
                <TabItem Header="Keyboard Lighting" Tag="loc:Tabs.KeyboardLighting" x:Name="KeyboardLightingPanel">
                    <ScrollViewer>
                        <StackPanel Margin="10,0,20,0">
                            <TextBlock Text="Keyboard Lighting" Tag="loc:Keyboard.Title" Classes="SectionHeader" />

                            <Border Classes="Card" x:Name="KeyboardEffectsPanel">
                                <StackPanel>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="RGB Mode" Tag="loc:Keyboard.RgbMode" Classes="SubHeader" />
                                        <material:MaterialIcon Grid.Column="1" Kind="KeyboardOutline" Width="24"
                                                               Height="24" HorizontalAlignment="Right" />
                                    </Grid>

                                    <Grid ColumnDefinitions="260,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0 8 0 0">
                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="Mode" Tag="loc:Keyboard.Mode" Opacity="0.7" />
                                            <ComboBox x:Name="LightingModeComboBox" SelectedIndex="0"
                                                      HorizontalAlignment="Stretch">
                                                <ComboBoxItem Content="Static" Tag="loc:Keyboard.Static" />
                                                <ComboBoxItem Content="Breathing" Tag="loc:Keyboard.Breathing" />
                                                <ComboBoxItem Content="Neon" Tag="loc:Keyboard.Neon" />
                                                <ComboBoxItem Content="Wave" Tag="loc:Keyboard.Wave" />
                                                <ComboBoxItem Content="Shifting" Tag="loc:Keyboard.Shifting" />
                                                <ComboBoxItem Content="Zoom" Tag="loc:Keyboard.Zoom" />
                                            </ComboBox>
                                        </StackPanel>

                                        <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,*,*,*" Margin="20,8,0,0">
                                            <Border Grid.Column="0" Background="#4287f5" Height="42" CornerRadius="4"
                                                    Margin="0,0,6,0" />
                                            <Border Grid.Column="1" Background="#ff5733" Height="42" CornerRadius="4"
                                                    Margin="0,0,6,0" />
                                            <Border Grid.Column="2" Background="#33ff57" Height="42" CornerRadius="4"
                                                    Margin="0,0,6,0" />
                                            <Border Grid.Column="3" Background="#ffff01" Height="42" CornerRadius="4" />
                                        </Grid>

                                        <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*,Auto"
                                              Margin="0 18 0 0">
                                            <TextBlock Grid.Column="0" Text="Brightness" Tag="loc:Keyboard.Brightness" Width="90"
                                                       VerticalAlignment="Center" />
                                            <Slider x:Name="KeyBrightnessSlider" Grid.Column="1" Value="100"
                                                    Minimum="0" Maximum="100" TickFrequency="10"
                                                    IsSnapToTickEnabled="True" />
                                            <TextBlock x:Name="KeyBrightnessText" Grid.Column="2" Text="100%"
                                                       Width="44" TextAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>

                                        <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*,Auto"
                                              Margin="0 8 0 0">
                                            <TextBlock Grid.Column="0" Text="Speed" Tag="loc:Keyboard.Speed" Width="90"
                                                       VerticalAlignment="Center" />
                                            <Slider x:Name="LightingSpeedSlider" Grid.Column="1" Value="5"
                                                    Minimum="0" Maximum="9" TickFrequency="1"
                                                    IsSnapToTickEnabled="True" />
                                            <TextBlock x:Name="LightSpeedTextBlock" Grid.Column="2" Text="5"
                                                       Width="44" TextAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>

                                        <Grid Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="Auto,*,Auto"
                                              Margin="0 10 0 0">
                                            <TextBlock Grid.Column="0" Text="Effect Color" Tag="loc:Keyboard.EffectColor" Width="90"
                                                       VerticalAlignment="Center" />
                                            <ColorPicker x:Name="LightEffectColorPicker" Grid.Column="1"
                                                         IsAlphaEnabled="False"
                                                         HexInputAlphaPosition="Trailing"
                                                         Color="#0078D7"
                                                         Height="50"
                                                         Width="220"
                                                         HorizontalAlignment="Left" />
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                                <RadioButton x:Name="LeftToRightRadioButton" GroupName="DirectionGroup"
                                                             IsChecked="True" Width="72" Height="56" Padding="8,4">
                                                    <material:MaterialIcon Kind="ArrowRight" Width="28" Height="28" />
                                                </RadioButton>
                                                <RadioButton x:Name="RightToLeftRadioButton" GroupName="DirectionGroup"
                                                             Width="72" Height="56" Padding="8,4">
                                                    <material:MaterialIcon Kind="ArrowLeft" Width="28" Height="28" />
                                                </RadioButton>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>

                                    <Button x:Name="LightingEffectsApplyButton" Content="Apply Effect" Tag="loc:Keyboard.ApplyEffect"
                                            HorizontalAlignment="Left" Margin="0 16 0 0" />
                                </StackPanel>
                            </Border>

                            <Border Classes="Card" x:Name="ZoneColorControlPanel">
                                <StackPanel>
                                    <TextBlock Text="Static Zone Colors" Tag="loc:Keyboard.StaticZoneColors" Classes="SubHeader" />

                                    <Grid ColumnDefinitions="*,*,*,*" Margin="0 8 0 0">
                                        <StackPanel Grid.Column="0" Margin="0 0 10 0">
                                            <TextBlock Text="Zone 1" Tag="loc:Keyboard.Zone1" />
                                            <ColorPicker x:Name="Zone1ColorPicker" IsAlphaEnabled="False"
                                                         IsAlphaVisible="False" HexInputAlphaPosition="Trailing"
                                                         Color="#4287f5" Height="50" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0 0 10 0">
                                            <TextBlock Text="Zone 2" Tag="loc:Keyboard.Zone2" />
                                            <ColorPicker x:Name="Zone2ColorPicker" IsAlphaEnabled="False"
                                                         IsAlphaVisible="False" HexInputAlphaPosition="Trailing"
                                                         Color="#ff5733" Height="50" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0 0 10 0">
                                            <TextBlock Text="Zone 3" Tag="loc:Keyboard.Zone3" />
                                            <ColorPicker x:Name="Zone3ColorPicker" IsAlphaEnabled="False"
                                                         IsAlphaVisible="False" HexInputAlphaPosition="Trailing"
                                                         Color="#33ff57" Height="50" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Text="Zone 4" Tag="loc:Keyboard.Zone4" />
                                            <ColorPicker x:Name="Zone4ColorPicker" IsAlphaEnabled="False"
                                                         IsAlphaVisible="False" HexInputAlphaPosition="Trailing"
                                                         Color="#ffff01" Height="50" />
                                        </StackPanel>
                                    </Grid>

                                    <Button x:Name="ApplyKeyboardColorsButton" Content="Apply Zone Colors" Tag="loc:Keyboard.ApplyZoneColors"
                                            HorizontalAlignment="Left" Margin="0 16 0 0" />
                                </StackPanel>
                            </Border>

                            <!-- Backlight Timeout -->
                            <Border Classes="Card" x:Name="BacklightTimeoutControls">
                                <StackPanel>
                                    <TextBlock Text="Backlight Timeout" Tag="loc:Keyboard.BacklightTimeout" Classes="SubHeader" />
                                    <TextBlock
                                        Text="Automatically turn off keyboard lighting after period of inactivity"
                                        Tag="loc:Keyboard.BacklightTimeoutHelp"
                                        Opacity="0.7" Margin="0 0 0 10" />

                                    <CheckBox x:Name="BacklightTimeoutCheckBox"
                                              Content="Enable backlight timeout (30 seconds)" Tag="loc:Keyboard.EnableBacklightTimeout" IsChecked="True"
                                              Margin="0 10" />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- System Settings Tab -->
                <TabItem Header="System Settings" Tag="loc:Tabs.SystemSettings" x:Name="SystemSettingsPanel">
                    <ScrollViewer>
                        <StackPanel Margin="10,0,20,0">
                            <TextBlock Text="System Settings" Tag="loc:Settings.Title" Classes="SectionHeader" />

                            <Border Classes="Card">
                                <StackPanel>
                                    <TextBlock Text="Language" Tag="loc:Common.Language" Classes="SubHeader" />
                                    <TextBlock Text="Choose the interface language" Tag="loc:Settings.LanguageHelp"
                                               Opacity="0.7" Margin="0 0 0 10" />
                                    <ComboBox x:Name="LanguageComboBox" Width="260" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <!-- LCD Override -->
                            <Border Classes="Card" x:Name="LcdOverrideControls">
                                <StackPanel>
                                    <TextBlock Text="LCD Override" Tag="loc:Settings.LcdOverride" Classes="SubHeader" />
                                    <TextBlock Text="Reduce LCD latency and minimize ghosting" Tag="loc:Settings.LcdOverrideHelp" Opacity="0.7"
                                               Margin="0 0 0 10" />

                                    <CheckBox x:Name="LcdOverrideCheckBox" Content="Enable LCD Override" Tag="loc:Settings.EnableLcdOverride"
                                              IsChecked="True" Margin="0 10" />
                                    <TextBlock Text="Note: May increase battery consumption" Tag="loc:Settings.BatteryConsumptionNote" Foreground="#FFA500"
                                               FontSize="12" Margin="0 5" />
                                </StackPanel>
                            </Border>

                            <!-- Boot Sound and Animation -->
                            <Border Classes="Card" x:Name="BootSoundControls">
                                <StackPanel>
                                    <TextBlock Text="Boot Sound and Animation" Tag="loc:Settings.BootSoundAnimation" Classes="SubHeader" />
                                    <TextBlock Text="Enable or disable custom boot animation and sound" Tag="loc:Settings.BootSoundAnimationHelp" Opacity="0.7"
                                               Margin="0 0 0 10" />

                                    <CheckBox x:Name="BootAnimAndSoundCheckBox"
                                              Content="Enable boot animation and sound" Tag="loc:Settings.EnableBootSoundAnimation" IsChecked="False" Margin="0 10" />
                                </StackPanel>
                            </Border>

                            <!-- System Information -->
                            <Border Classes="Card">
                                <StackPanel>
                                    <TextBlock Text="System Information" Tag="loc:Settings.SystemInformation" Classes="SubHeader" />

                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                          Margin="0 10">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Model:" Tag="loc:Settings.Model" FontWeight="SemiBold"
                                                   Width="120" Margin="0 10 0 0" />
                                        <TextBlock x:Name="ModelNameText" Grid.Row="0" Grid.Column="1" Text="UNKNOWN"
                                                   Margin="5 10 0 0" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Laptop Type:" Tag="loc:Settings.LaptopType"
                                                   FontWeight="SemiBold" Width="120" Margin="0 10 0 0" />
                                        <TextBlock x:Name="LaptopTypeText" Grid.Row="1" Grid.Column="1" Text="UNKNOWN"
                                                   Margin="5 10 0 0" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Features:" Tag="loc:Settings.Features" FontWeight="SemiBold"
                                                   Width="120" Margin="0 10 0 0" />
                                        <TextBlock x:Name="SupportedFeaturesTextBlock" Grid.Row="2" Grid.Column="1"
                                                   Text="UNKNOWN" Margin="5 10 0 0" TextWrapping="Wrap" />

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Project Version:" Tag="loc:Settings.ProjectVersion"
                                                   FontWeight="SemiBold" Width="120" Margin="0 10 0 0" />
                                        <TextBlock x:Name="ProjectVersionText" Grid.Row="5" Grid.Column="1"
                                                   Text="UNKNOWN" Margin="5 10 0 0" />


                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Daemon Version:" Tag="loc:Settings.DaemonVersion"
                                                   FontWeight="SemiBold" Width="120" Margin="0 10 0 0" />
                                        <TextBlock x:Name="DaemonVersionText" Grid.Row="3" Grid.Column="1"
                                                   Text="UNKNOWN" Margin="5 10 0 0" />

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Driver Version:" Tag="loc:Settings.DriverVersion"
                                                   FontWeight="SemiBold" Width="120" Margin="0 10 0 0" />
                                        <TextBlock x:Name="DriverVersionText" Grid.Row="4" Grid.Column="1"
                                                   Text="UNKNOWN" Margin="5 10 0 0" />

                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Stretch">
                                        <Button x:Name="UpdatesButton" Content="Check for Updates" Tag="loc:Settings.CheckUpdates" Margin="0 15 0 0"
                                                Click="UpdatesButton_OnClick" />
                                        <Button x:Name="DeveloperModeButton" Content="Developer Mode" Tag="loc:Settings.DeveloperMode" Margin="0 15 0 0"
                                                IsVisible="False"
                                                Click="DeveloperMode_OnClick" />
                                        <Button x:Name="IssuePageButton" Content="Issue/Feedback" Tag="loc:Settings.IssueFeedback" Margin="0 15 0 0"
                                                Click="IssuePageButton_OnClick" />
                                        <Button x:Name="InternalsManagerButton" Content="Internals Manager" Tag="loc:Settings.InternalsManager"
                                                Margin="0 15 0 0"
                                                Click="InternalsMangerWindow_OnClick" />


                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Overlay Grid (on separate layer) -->
        <Grid x:Name="DaemonErrorGrid" Panel.ZIndex="100" Background="Transparent" IsHitTestVisible="True"
              IsVisible="True">
            <Border
                BorderBrush="#333236"
                BorderThickness="3"
                CornerRadius="20"
                Padding="30"
                Width="400"
                Height="280"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%, 100%">
                        <GradientStop Offset="0" Color="#18181b" />
                        <GradientStop Offset="1" Color="#242429" />
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                    <!-- Material Icon -->
                    <material:MaterialIcon Kind="Connection" Foreground="#FF5A5F" Width="48" Height="48"
                                           HorizontalAlignment="Center" />
                    <StackPanel Spacing="0">
                        <!-- Message -->
                        <TextBlock Text="Daemon not connected"
                                   Tag="loc:Daemon.NotConnected"
                                   Foreground="White"
                                   FontSize="18"
                                   HorizontalAlignment="Center"
                                   Classes="SectionHeader"
                                   Margin="0,12,0,0" />

                        <TextBlock
                            Text="Daemon may be initializing. Please wait a minute. If issues persists, check logs."
                            Tag="loc:Daemon.NotConnectedHelp"
                            Foreground="White"
                            FontSize="13"
                            TextWrapping="Wrap"
                            HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Retry Button -->
                    <Button Content="Retry"
                            Tag="loc:Common.Retry"
                            Width="100"
                            HorizontalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            Click="RetryConnectionButton_OnClick" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
